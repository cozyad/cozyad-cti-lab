# OpenCTI Platform
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=your-strong-password-here
OPENCTI_ADMIN_TOKEN=your-uuid-token-here
OPENCTI_ENCRYPTION_KEY=your-32-char-encryption-key-here
OPENCTI_EXTERNAL_SCHEME=http
OPENCTI_HOST=localhost
OPENCTI_PORT=8080
OPENCTI_HEALTHCHECK_ACCESS_KEY=your-healthcheck-key-here

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=your-minio-password-here

# RabbitMQ
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=your-rabbitmq-password-here

# Elasticsearch
ELASTIC_MEMORY_SIZE=4g

# XTM Composer
XTM_COMPOSER_ID=your-uuid-here

# Connector UUIDs (generate with: python3 -c "import uuid; print(uuid.uuid4())")
CONNECTOR_EXPORT_FILE_STIX_ID=
CONNECTOR_EXPORT_FILE_CSV_ID=
CONNECTOR_EXPORT_FILE_TXT_ID=
CONNECTOR_IMPORT_FILE_STIX_ID=
CONNECTOR_IMPORT_DOCUMENT_ID=
CONNECTOR_IMPORT_FILE_YARA_ID=
CONNECTOR_ANALYSIS_ID=
CONNECTOR_IMPORT_EXTERNAL_REFERENCE_ID=
CONNECTOR_RANSOMWARE_LIVE_ID=
CONNECTOR_CISA_KEV_ID=
CONNECTOR_THREATFOX_ID=
CONNECTOR_URLHAUS_ID=
CONNECTOR_MALWAREBAZAAR_ID=
CONNECTOR_VIRUSTOTAL_ID=
CONNECTOR_OPENCTI_ID=
CONNECTOR_MITRE_ID=

# VirusTotal (optional enrichment)
VIRUSTOTAL_TOKEN=your-virustotal-api-key-here

# SMTP (optional)
SMTP__HOSTNAME=localhost

# Beast Intel MCP server
OPENCTI_URL=http://localhost:8080
OPENCTI_TOKEN=your-uuid-token-here

# ---- VM2: Windows detonation range (see docs/vm2_detonation_lab.md) ----
# Consumed by infra/gcp/create_windows_vm.sh
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=europe-west2
GCP_ZONE=europe-west2-a
VM1_INTERNAL_IP=10.0.0.2
VM2_NAME=cti-win-detonation
VM2_MACHINE_TYPE=e2-standard-2
VPC_NETWORK=default
VPC_SUBNET=default
